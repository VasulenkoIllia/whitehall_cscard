# ─── Database (docker-compose підставляє автоматично через environment:) ───────
DATABASE_URL=postgres://whitehall_store:whitehall_store@db:5432/whitehall_store

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_STRATEGY=db
# Мінімум 32 символи, генерувати: openssl rand -hex 32
AUTH_SESSION_SECRET=ЗАМІНИ_НА_РАНДОМНИЙ_РЯДОК_openssl_rand_hex_32
AUTH_SESSION_TTL_MINUTES=720

# Використовується ТІЛЬКИ для npm run seed:users (один раз при деплої).
# Після того як запустив seed — можна залишити або очистити.
# Як згенерувати хеш пароля: npm run hash-password ТвійПароль
AUTH_USERS_JSON='[
  {"email":"admin1@example.com","password_hash":"$2a$12$...","role":"admin"},
  {"email":"admin2@example.com","password_hash":"$2a$12$...","role":"admin"},
  {"email":"viewer@example.com","password_hash":"$2a$12$...","role":"viewer"}
]'

# ─── Google Sheets (для імпорту даних від постачальників) ────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# ─── CS-Cart store ────────────────────────────────────────────────────────────
CSCART_URL=https://your-store.com
CSCART_API_ID=your_api_id
CSCART_API_KEY=your_api_key

# ─── Active store connector ───────────────────────────────────────────────────
ACTIVE_STORE=cscart
