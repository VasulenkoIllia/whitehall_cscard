{
  "name": "whitehall_cscard",
  "version": "1.0.0",
  "description": "Modular CS-Cart integration foundation for Whitehall",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "start": "node dist/index.js",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "seed:users": "node dist/scripts/seedUsers.js",
    "migrate": "node dist/scripts/runMigrations.js",
    "mirror:sync": "node dist/scripts/runStoreMirrorSync.js",
    "store:sku-audit": "node dist/scripts/runStoreSkuAudit.js",
    "backend:readiness": "node dist/scripts/runBackendReadiness.js",
    "audit:load": "node dist/scripts/runLoadAudit.js",
    "audit:stress": "node dist/scripts/runStressAudit.js",
    "test:invariants": "node dist/scripts/runInvariantIntegrationTests.js",
    "export:legacy-config": "node dist/scripts/exportLegacySupplierConfig.js",
    "import:legacy-config": "node dist/scripts/importSupplierConfigSnapshot.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.19.2",
    "googleapis": "^140.0.1",
    "node-fetch": "2.6.7",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.6",
    "@types/node-fetch": "2.6.11",
    "typescript": "^5.5.3"
  },
  "private": true
}
